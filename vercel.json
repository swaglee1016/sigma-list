{
  "installCommand": "npm install",
  "buildCommand": "npx vite build && node -e \"require('fs').mkdirSync('dist/api',{recursive:true});require('fs').copyFileSync('api/sync.mjs','dist/api/sync.mjs')\"",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
