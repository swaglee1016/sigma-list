{
  "installCommand": "npm install",
  "buildCommand": "npx vite build",
  "functions": {
    "api/sync.js": {
      "runtime": "@vercel/node@3"
    }
  },
  "rewrites": [
    { "source": "/assets/(.*)", "destination": "/dist/assets/$1" },
    { "source": "/(.*)", "destination": "/dist/index.html" }
  ]
}
